      <div class="modal-header">
        <h5 class="modal-title text-main">پیام کاربر</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="بستن"></button>
      </div>
      <div class="modal-body">
        <div class="text-muted" id="msgModalBody"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-main-outline" data-bs-dismiss="modal">بستن</button>
        
      </div>


      
    </div>
  </div>
</div>
<script>
  document.addEventListener('DOMContentLoaded', function() {
      function tick() {
          const d = new Date();
          const el = document.getElementById('adminClock');
          if (el) el.textContent = `${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`;
      }
      tick();
      setInterval(tick, 30000);
  
      document.querySelectorAll('.js-confirm-delete').forEach(form => {
          form.addEventListener('submit', (e) => { if (!confirm('آیا مطمئن هستید؟')) e.preventDefault(); });
      });
  
      document.getElementById('adminGlobalSearch')?.addEventListener('input', (e) => {
          const query = e.target.value.toLowerCase();
          const activePane = document.querySelector('.tab-pane.active');
          activePane?.querySelectorAll('tbody tr').forEach(tr => {
              tr.style.display = tr.innerText.toLowerCase().includes(query) ? '' : 'none';
          });
      });
  
      const imageInput = document.getElementById('productImageInput');
      const imagePreview = document.getElementById('productImagePreview');
      const imagePlaceholder = document.getElementById('productImagePlaceholder');
      const resetBtn = document.getElementById('btnResetProductForm');
  
      imageInput?.addEventListener('change', function(e) {
          const file = e.target.files[0];
          if (file) {
              const reader = new FileReader();
              reader.onload = (ev) => {
                  imagePreview.src = ev.target.result;
                  imagePreview.classList.remove('d-none');
                  imagePlaceholder.classList.add('d-none');
              };
              reader.readAsDataURL(file);
          }
      });
  
      resetBtn?.addEventListener('click', () => {
          setTimeout(() => {
              imagePreview.classList.add('d-none');
              imagePlaceholder.classList.remove('d-none');
          }, 10);
      });
  
      const socket = io();
  
      function createOrderRow(order) {
          const tr = document.createElement("tr");
          tr.dataset.id = order._id;
          
          const total = (order.order || []).reduce((sum, item) => sum + (item.productId?.price || 0) * (item.quantity || 1), 0);
          const itemsHtml = (order.order || []).map(item => 
              `<li class="text-muted">${item.productId?.iteamName || 'محصول حذف شده'} × ${item.quantity}</li>`
          ).join("");
  
          let innerHtml = `
              <td class="fw-semibold text-main">میز ${order.table || "-"}</td>
              <td><ul class="list-unstyled mb-0 small">${itemsHtml}</ul></td>
              <td class="fw-semibold text-main">${total} تومان</td>
          `;
  
if (order.status !== 'delivered') {
    const nextStatus = order.status === 'pending' ? 'preparing' : 'delivered';
    const actionText = order.status === 'pending' ? 'شروع آماده‌سازی' : 'تحویل سفارش';
    const icon = order.status === 'pending' ? 'bi-play-fill' : 'bi-check2';

    innerHtml += `
        <td>
            <form method="post" action="/admin/order/status/${order._id}" class="m-0">
                <input type="hidden" name="status" value="${nextStatus}">
                <button class="btn btn-sm btn-main" type="submit">
                    <i class="bi ${icon}"></i> ${actionText}
                </button>
            </form>
        </td>
    `;
}

  
          tr.innerHTML = innerHtml;
          return tr;
      }
  
      socket.on("newOrder", (order) => {
          const target = document.querySelector("#pending-orders-body");
          if (target) {
              const emptyRow = target.querySelector('td[colspan]');
              if (emptyRow) emptyRow.parentElement.remove();
              
              target.prepend(createOrderRow(order));
          }
      });
  
      socket.on("orderStatusChanged", (order) => {
          document.querySelector(`[data-id="${order._id}"]`)?.remove();
          
          const target = document.querySelector(`#${order.status}-orders-body`);
          if (target) {
              const emptyRow = target.querySelector('td[colspan]');
              if (emptyRow) emptyRow.parentElement.remove();
              
              target.prepend(createOrderRow(order));
          }
      });
  });
  </script>
  
  

