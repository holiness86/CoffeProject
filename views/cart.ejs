<%- include('./includes/header.ejs') %>

<main class="cart-page py-4 py-lg-5">
  <section class="hero-section mb-4 text-center">
    <div class="container">
      <h1 class="display-5 fw-bold text-main mb-2">لیست سفارش شما 🛒</h1>
      <p class="text-muted mb-0">اقلام انتخاب‌شده را بررسی کنید و سفارش دهید.</p>
    </div>
  </section>

  <section class="container">
    <div class="row g-4 align-items-start">

      <div class="col-lg-8">

        <div class="card shadow-main overflow-hidden">
          <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
            <div>
              <h2 class="h5 text-main mb-0">لیست سفارش</h2>
              <small class="text-muted">تعداد آیتم‌ها: <span id="cartTotalQty">0</span></small>
            </div>

            <a href="/" class="btn btn-main-outline btn-sm">
              <i class="bi bi-arrow-right"></i>
              برگشت به منو
            </a>
          </div>

          <div class="card-body p-3 p-lg-4">

            <% if (cartItems && cartItems.length > 0) { %>

              <div id="cartItemsWrap" class="d-grid gap-3">
                <% cartItems.forEach(item => { %>
                  <div class="cart-item card border-0 shadow-sm rounded-md p-3"
                       data-item-id="<%= item._id %>"
                       data-product-id="<%= item.productId %>"
                       data-price="<%= item.price %>">

                    <div class="d-flex gap-3 align-items-start">
                      <img
                        src="<%= item.picture || '/assets/images/placeholder.png' %>"
                        alt="<%= item.name %>"
                        class="cart-thumb rounded-md"
                        loading="lazy"
                        onerror="this.style.display='none';"
                      />

                      <div class="flex-grow-1">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                          <div>
                            <div class="fw-semibold text-main"><%= item.name %></div>
                            <div class="text-muted small mt-1">
                              قیمت واحد:
                              <span class="fw-semibold"><%= item.price.toLocaleString() %></span>
                              تومان
                            </div>
                          </div>

                          <button type="button"
                                  class="btn btn-sm btn-link text-danger p-0 js-remove"
                                  title="کم کردن / حذف"
                                  aria-label="کم کردن">
                            <i class="bi bi-trash text-main fs-5"></i>
                          </button>
                        </div>

                        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-3">

                          <div class="qty-control d-inline-flex align-items-center gap-2">
                            <button type="button" class="btn btn-main-outline btn-sm js-dec" aria-label="کم کردن">−</button>
                            <span class="badge bg-accent text-main px-3 py-2 js-qty"><%= item.quantity %></span>
                            <button type="button" class="btn btn-main btn-sm js-inc" aria-label="زیاد کردن">+</button>
                          </div>

                          <div class="text-end">
                            <div class="text-muted small">جمع این آیتم</div>
                            <div class="fw-bold text-main">
                              <span class="js-line-total"><%= (item.price * item.quantity).toLocaleString() %></span>
                              تومان
                            </div>
                          </div>

                        </div>
                      </div>
                    </div>

                  </div>
                <% }) %>
              </div>

              <div class="alert alert-info mt-4 mb-0 d-none" id="cartEmptyState">
                <p class="mb-0 text-center">لیست سفارش شما خالی است ☕</p>
              </div>

            <% } else { %>

              <div class="alert alert-info text-center mb-0">
                <p class="mb-0">لیست سفارش شما خالی است ☕</p>
              </div>

            <% } %>

          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card shadow-main sticky-top" style="top: 90px;">
          <div class="card-body p-3 p-lg-4">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <span class="text-muted">جمع کل</span>
              <span class="h5 text-main m-0">
                <span id="cartTotalPrice">
                  <%= cartItems && cartItems.length
                    ? cartItems.reduce((sum, item) => sum + (item.price * item.quantity), 0).toLocaleString()
                    : 0 %>
                </span>
                تومان
              </span>
            </div>

            <div class="text-muted small mb-3">
              پرداخت در محل (میز) • ارسال سفارش به صندوق
            </div>

            <form action="/order" method="POST" class="cart-submit row g-2">
              <div class="col-12">
                <label for="table" class="form-label text-main mb-1">شماره میز</label>
                <input
                  type="number"
                  class="form-control"
                  name="table"
                  id="table"
                  required
                  min="1"
                  max="<%= setings.tableNumber %>"
                  placeholder="مثلاً ۱۲"
                />
              </div>

              <div class="col-12 d-grid mt-2">
                <button type="submit" class="btn btn-main btn-lg" id="btnSubmitOrder">
                  ارسال سفارش
                </button>
              </div>
            </form>

            <hr class="my-3 opacity-25" />

            <div class="d-grid gap-2">
              <a href="/#products" class="btn btn-main-outline">
                ادامه خرید
              </a>
            </div>

          </div>
        </div>
      </div>

    </div>
  </section>
</main>

<script>
(function(){
  const fmt = (n) => {
    try { return (Number(n)||0).toLocaleString('fa-IR'); } catch { return String(n||0); }
  };

  function getCartNodes(){
    return Array.from(document.querySelectorAll('.cart-item'));
  }

  function calcTotals(){
    const items = getCartNodes();
    let totalQty = 0;
    let totalPrice = 0;

    items.forEach(card => {
      const price = Number(card.getAttribute('data-price') || 0);
      const qty = Number(card.querySelector('.js-qty')?.textContent || 0);
      totalQty += qty;
      totalPrice += price * qty;
    });

    document.getElementById('cartTotalQty')?.replaceChildren(document.createTextNode(String(totalQty)));
    const totalPriceEl = document.getElementById('cartTotalPrice');
    if (totalPriceEl) totalPriceEl.textContent = fmt(totalPrice);

    const empty = document.getElementById('cartEmptyState');
    if (empty){
      empty.classList.toggle('d-none', items.length !== 0);
    }

    const btn = document.getElementById('btnSubmitOrder');
    if (btn) btn.disabled = items.length === 0;
  }

  async function postJSON(url){
    const res = await fetch(url, {
      method: 'POST',
      headers: {
        'X-Requested-With': 'XMLHttpRequest',
        'Accept': 'application/json'
      }
    });

    const ct = (res.headers.get('content-type') || '').toLowerCase();
    const data = ct.includes('application/json') ? await res.json() : null;

    if (!res.ok) throw new Error(data?.error || data?.message || 'خطای سرور');
    return data;
  }

  function updateCardUI(card, newQty){
    const price = Number(card.getAttribute('data-price') || 0);
    const qtyEl = card.querySelector('.js-qty');
    const lineEl = card.querySelector('.js-line-total');

    if (qtyEl) qtyEl.textContent = String(newQty);
    if (lineEl) lineEl.textContent = fmt(price * newQty);

    card.style.transition = 'transform 140ms cubic-bezier(.2,.8,.2,1)';
    card.style.transform = 'scale(1.01)';
    setTimeout(()=> card.style.transform = 'scale(1)', 140);
  }

  document.addEventListener('click', async function(e){
    const card = e.target.closest('.cart-item');
    if (!card) return;

    const itemId = card.getAttribute('data-item-id');
    const productId = card.getAttribute('data-product-id');

    const qtyEl = card.querySelector('.js-qty');
    const currentQty = Number(qtyEl?.textContent || 0);

    if (e.target.closest('.js-inc')){
      if (!productId) return window.showAppToast?.('productId برای این آیتم موجود نیست', 'danger');

      updateCardUI(card, currentQty + 1);
      calcTotals();

      try {
        await postJSON(`/cart/add/${productId}`);
        window.CartUI?.refresh();
      } catch(err){
        updateCardUI(card, currentQty);
        calcTotals();
        window.showAppToast?.(err?.message || 'خطا در افزودن', 'danger');
      }
      return;
    }

    if (e.target.closest('.js-dec') || e.target.closest('.js-remove')){
      if (!itemId) return;

      if (currentQty <= 0) return;

      const nextQty = currentQty - 1;

      if (nextQty <= 0){
        card.style.opacity = '0.2';
      } else {
        updateCardUI(card, nextQty);
      }
      calcTotals();

      try{
        await postJSON(`/cart/delete/${itemId}`);

        if (nextQty <= 0){
          card.remove();
          calcTotals();
        }

        window.CartUI?.refresh();
      }catch(err){
        card.style.opacity = '';
        updateCardUI(card, currentQty);
        calcTotals();
        window.showAppToast?.(err?.message || 'خطا در کم کردن/حذف', 'danger');
      }
      return;
    }
  });

  window.addEventListener('DOMContentLoaded', function(){
    calcTotals();
  });
})();
</script>

<%- include('./includes/Footer.ejs') %>
